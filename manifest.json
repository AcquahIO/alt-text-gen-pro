{
  "manifest_version": 3,
  "name": "Alt Text Generator Pro",
  "version": "0.1.0",
  "description": "Generate high-quality alt text for images via context menu or uploads.",
  "default_locale": "en",
  "permissions": ["contextMenus", "storage", "identity", "alarms"],
  "host_permissions": [
    "http://localhost:8787/*",
    "https://alt-text-gen-pro-backend.herokuapp.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Alt Text Generator",
    "default_popup": "ui-dist/popup.html",
    "default_icon": {
      "16": "icons/action-icon-16.png",
      "32": "icons/action-icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["ui-dist/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png",
    "512": "icons/icon-512.png",
    "1024": "icons/icon-1024.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
